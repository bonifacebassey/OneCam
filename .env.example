# Copy to .env and adjust as needed.

# Server
HOST=0.0.0.0
PORT=8000

# Camera registry file (relative to project root)
CAMERAS_FILE=cameras.json

# Directory where snapshots are saved
SNAPSHOTS_DIR=snapshots

# Seconds to wait for camera to respond before timing out
PROXY_TIMEOUT=10.0

# Motion detection
MOTION_POLL_INTERVAL=2.0        # seconds between frame grabs
MOTION_THRESHOLD=0.02           # mean pixel diff (0–1) that triggers motion
MOTION_COOLDOWN_SECONDS=5.0     # minimum seconds between consecutive alerts

DEBUG=false
